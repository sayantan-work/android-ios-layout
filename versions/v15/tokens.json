{
  "name": "Mainframe",
  "tagline": "IBM punch card meets techie minimal · manila + CRT amber + IBM Plex Mono",
  "lineage": ["IBM 80-column punch card (1928–1980s)", "IBM mainframe terminals", "COBOL bracket typography", "IBM Plex Mono"],
  "color": {
    "_canvas": "Pure white page · manila card stock for heroes",
    "bg": "#FFFFFF",
    "surface": "#FFFFFF",
    "surface2": "#FAFAFA",
    "surface3": "#F4F4F5",

    "_card": "Manila punch-card paper — used for hero surfaces, attendance, profile",
    "card": "#F2EAD3",
    "card2": "#E8DCB8",
    "card3": "#DBC992",

    "_ink": "Warm dark navy — looks like printed letterpress ink",
    "text": "#0E1A2B",
    "text2": "#4A5A6E",
    "text3": "#8696A8",
    "ink": "#0E1A2B",
    "onInk": "#F2EAD3",

    "_accent": "CRT amber — the 'punched' / active color (kept on --sage* for script compat)",
    "sage": "#FF6B00",
    "sageSoft": "#FFE5CC",
    "sageDeep": "#C24F00",

    "_crt": "Old-terminal green — live status, success",
    "crt": "#00BF63",
    "crtSoft": "#CFFAE3",
    "crtDeep": "#007A3F",

    "_ibm": "IBM blue — sparingly, for info/AI moments",
    "ibm": "#0F62FE",
    "ibmSoft": "#E0E9FF",
    "ibmDeep": "#0043B8",

    "amber": "#F59E0B",
    "amberSoft": "#FEF3C7",
    "red": "#DC2626",
    "redSoft": "#FEE2E2",

    "line": "#E5E5E5",
    "cardLine": "#C8B98A",
    "cardLine2": "#A8995F"
  },
  "radius": {
    "_note": "Sharp — card stock isn't rounded. Pill kept for status dots only.",
    "none": 0, "sm": 2, "md": 3, "lg": 4, "xl": 6, "pill": 9999
  },
  "font": {
    "sans": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', system-ui, sans-serif",
    "mono": "'IBM Plex Mono', 'JetBrains Mono', 'SF Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
    "featureSettings": "'tnum','ss01','zero'",
    "_note": "Mono everywhere for times, numbers, codes, labels. Sans for body copy only."
  },
  "type": {
    "hero": { "size": 38, "weight": 700, "letterSpacing": "-0.02em", "family": "mono" },
    "title": { "size": 24, "weight": 700, "letterSpacing": "-0.02em", "family": "mono" },
    "h2": { "size": 14, "weight": 800, "letterSpacing": "0.10em", "transform": "uppercase", "family": "mono" },
    "row": { "size": 14.5, "weight": 700 },
    "section": { "size": 11, "weight": 700, "letterSpacing": "0.16em", "transform": "uppercase", "family": "mono", "decoration": "[ BRACKETS ]" }
  },
  "elevation": {
    "_note": "Stamped / mechanical feel — 4px hard-offset shadows instead of soft blurs",
    "subtle": "0 1px 0 rgba(14,26,43,0.06), 0 0 0 1px var(--line)",
    "card": "0 2px 0 rgba(14,26,43,0.10), 0 0 0 1px var(--card-line)",
    "hero": "0 4px 0 rgba(14,26,43,0.12), 0 0 0 1.5px var(--card-line)",
    "btn": "4px 4px 0 var(--sage-deep)"
  },
  "phone": { "width": 340, "height": 736, "radius": 42, "bezel": 6 }
}
