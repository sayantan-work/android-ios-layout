    "zepto": { "primary": "#E2007A", "secondary": "#FCD34D", "tertiary": "#7C3AED", "accent": "#10B981" },
    "phonepe": { "primary": "#5F259F", "secondary": "#00C853", "tertiary": "#FBC02D", "accent": "#00ACC1" }
