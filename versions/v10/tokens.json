{
  "name": "Field Ledger",
  "tagline": "Editorial newspaper meets employee logbook",
  "color": {
    "_paper": "Cream paper canvas, whisper-faint ruled lines",
    "bg":         "#F4EFE2",
    "bgRule":     "#E4DCC4",
    "surface":    "#FFFCF6",
    "surface2":   "#EFE9D9",
    "surface3":   "#E5DDC4",

    "_ink": "Deep warm-black ink, like a fountain pen on cream",
    "text":       "#1A1612",
    "text2":      "#5C5246",
    "text3":      "#8C8273",
    "text4":      "#B6AC97",

    "ink":        "#1A1612",
    "onInk":      "#FAF6E8",

    "_accent": "Stamp-red — the only saturated color in the system",
    "sage":       "#A63D40",
    "sageSoft":   "#F1DCD2",
    "sageDeep":   "#6E1E20",

    "_secondary": "Forest ink for 'approved', mustard for 'pending', amber not used (too consumer)",
    "amber":      "#A8842A",
    "amberSoft":  "#F2E6BF",
    "red":        "#7C2D2D",
    "redSoft":    "#F4DDD8",
    "forest":     "#2D5F4F",
    "forestSoft": "#DCE7DE",

    "line":       "#D6CFC0",
    "lineStrong": "#B6AC97",
    "rule":       "#E4DCC4",

    "_shadow": "Like sheets of paper on a desk — soft, ambient, never crisp",
    "shadowRing":     "rgba(60,40,20,0.08)",
    "shadowAmbient":  "rgba(60,40,20,0.04)"
  },
  "radius": { "none": 0, "sm": 3, "md": 4, "lg": 6, "xl": 10, "pill": 9999 },
  "font": {
    "display":  "'Iowan Old Style', 'Hoefler Text', 'PT Serif', Georgia, 'Times New Roman', serif",
    "body":     "'Iowan Old Style', 'Hoefler Text', 'PT Serif', Georgia, serif",
    "ui":       "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', system-ui, sans-serif",
    "numerals": "'Iowan Old Style', 'Hoefler Text', 'PT Serif', Georgia, serif",
    "_note": "Serif for everything except dense UI (chips, tab labels, status bar). Numerals tabular wherever time/elapsed shown."
  },
  "type": {
    "masthead":  { "size": 32, "weight": 700, "letterSpacing": "-0.025em", "style": "italic" },
    "headline":  { "size": 22, "weight": 700, "letterSpacing": "-0.015em" },
    "h2":        { "size": 17, "weight": 700, "letterSpacing": "-0.005em" },
    "row":       { "size": 16, "weight": 400, "lineHeight": 1.45 },
    "body":      { "size": 15, "weight": 400, "lineHeight": 1.55 },
    "meta":      { "size": 13, "weight": 400, "style": "italic" },
    "smallCaps": { "size": 11, "weight": 700, "letterSpacing": "0.16em", "transform": "uppercase" },
    "stamp":     { "size": 12, "weight": 800, "letterSpacing": "0.22em", "transform": "uppercase" },
    "dropCap":   { "size": 56, "weight": 700, "letterSpacing": "-0.04em", "style": "italic" }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 24, "xxl": 32, "section": 48 },
  "phone":   { "width": 340, "height": 736, "radius": 42, "bezel": 6 },
  "stamp": {
    "_note": "The signature visual element. Today's attendance row gets a red-ink rubber-stamp impression.",
    "rotation":   "-3deg",
    "inkBleed":   "rgba(166,61,64,0.22) blur(0.6px)",
    "borderStyle":"2px solid #A63D40",
    "padding":    "5px 12px 4px",
    "letterSpacing": "0.22em",
    "weight":     800
  }
}
