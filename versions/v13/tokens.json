{
  "name": "Tiffin",
  "tagline": "Indian consumer-app DNA — Swiggy green · Zomato red · Zepto pink · Cult orange",
  "lineage": ["FoodDash (designmd.ai/chef/fooddash)", "Swiggy", "Zomato", "Zepto", "Cult.fit"],
  "color": {
    "_canvas": "Pure white with very-light grey neutrals (Swiggy/Zomato base)",
    "bg":        "#FFFFFF",
    "surface":   "#FFFFFF",
    "surface2":  "#FAFAFA",
    "surface3":  "#F4F4F5",

    "_ink": "Warm near-black (Zomato lineage, not the cold #0A0A0A of v11/v12)",
    "text":      "#171717",
    "text2":     "#525252",
    "text3":     "#A3A3A3",
    "text4":     "#D4D4D4",
    "ink":       "#171717",
    "onInk":     "#FFFFFF",

    "_accent": "Zomato red — primary CTAs + brand identity. Kept on --sage* for script compat.",
    "sage":      "#E23744",
    "sageSoft":  "#FEE7E9",
    "sageDeep":  "#B91C1C",

    "_palette": "Multi-color hierarchy — each color carries its own meaning (vs v11/v12 monochrome)",
    "orange":    "#F97316",
    "orangeSoft":"#FFEDD5",
    "pink":      "#EC4899",
    "pinkSoft":  "#FCE7F3",
    "sky":       "#0EA5E9",
    "skySoft":   "#E0F2FE",
    "violet":    "#8B5CF6",
    "violetSoft":"#EDE9FE",

    "_semantic": "Swiggy green = present/success. Pure red = error. Amber = warning.",
    "amber":     "#F59E0B",
    "amberSoft": "#FEF3C7",
    "red":       "#DC2626",
    "redSoft":   "#FEE2E2",
    "forest":    "#16A34A",
    "forestSoft":"#DCFCE7",

    "line":       "#F0F0F0",
    "line2":      "#F5F5F5",
    "lineStrong": "#D4D4D4"
  },
  "radius": { "none": 0, "sm": 8, "md": 12, "lg": 16, "xl": 20, "pill": 9999 },
  "font": {
    "stack": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', system-ui, sans-serif",
    "featureSettings": "'tnum','ss01','cv11'",
    "_note": "FoodDash uses Poppins for headlines + DM Sans for body. v13 keeps system sans (RN parity) but matches FoodDash's heavier weight rhythm (800/700/600/500)."
  },
  "type": {
    "hero":      { "size": 42, "weight": 800, "letterSpacing": "-0.04em" },
    "title":     { "size": 30, "weight": 800, "letterSpacing": "-0.03em" },
    "h2":        { "size": 18, "weight": 800, "letterSpacing": "-0.02em" },
    "row":       { "size": 15, "weight": 700 },
    "body":      { "size": 15, "weight": 600, "lineHeight": 1.5 },
    "meta":      { "size": 13, "weight": 600 },
    "chip":      { "size": 12, "weight": 800, "letterSpacing": "0.02em" },
    "section":   { "size": 11, "weight": 800, "letterSpacing": "0.10em", "transform": "uppercase" }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 24, "xxl": 32, "section": 48 },
  "phone":   { "width": 340, "height": 736, "radius": 42, "bezel": 6 },
  "elevation": {
    "_note": "FoodDash material-style shadows — cards lift more than v12. FAB pattern carries colored shadow (Zomato CTA energy).",
    "subtle":   "0 1px 3px rgba(23,23,23,0.06)",
    "card":     "0 4px 12px rgba(23,23,23,0.08), 0 1px 2px rgba(23,23,23,0.04)",
    "hero":     "0 8px 24px rgba(23,23,23,0.10), 0 2px 6px rgba(23,23,23,0.06)",
    "fab":      "0 8px 20px rgba(226,55,68,0.32), 0 2px 6px rgba(226,55,68,0.20)"
  }
}
